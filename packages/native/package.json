{
  "name": "@haloform/native",
  "version": "0.1.2",
  "description": "React Native adapter for haloform — prop mappers for TextInput and Switch",
  "license": "MIT",
  "author": "Angel Orellana",
  "homepage": "https://github.com/luisangel2895/haloform#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luisangel2895/haloform.git",
    "directory": "packages/native"
  },
  "bugs": {
    "url": "https://github.com/luisangel2895/haloform/issues"
  },
  "keywords": ["form", "react-native", "native", "validation", "headless", "typescript"],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@haloform/core": "^0.1.2",
    "@haloform/react": "^0.1.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  }
}
