{
  "name": "@haloform/react",
  "version": "0.1.1",
  "description": "React adapter for haloform — useForm and useMultiStepForm hooks",
  "license": "MIT",
  "author": "Angel Orellana",
  "homepage": "https://github.com/luisangel2895/haloform#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luisangel2895/haloform.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/luisangel2895/haloform/issues"
  },
  "keywords": ["form", "react", "hooks", "useForm", "validation", "headless", "typescript"],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@haloform/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
